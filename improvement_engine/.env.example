# NOTE: Environment variables are now in the root .env file
# Copy these settings to /path/to/repo/.env

# Shared LLM Configuration
IMPROVEMENT_BACKEND=lmstudio  # or openrouter, ollama
IMPROVEMENT_MODEL=local-model

# OpenRouter API Configuration (if using openrouter backend)
OPENROUTER_API_KEY=your_api_key_here

# LM Studio Configuration (if using lmstudio backend)
LMSTUDIO_HOST=192.168.1.104
LMSTUDIO_PORT=1234

# Ollama Configuration (if using ollama backend)
OLLAMA_HOST=localhost
OLLAMA_PORT=11434

# Application Settings
DEFAULT_BATCH_SIZE=10
LOG_LEVEL=INFO
BACKUP_ENABLED=true
