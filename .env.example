# Synaptic Tuner environment variables
# Copy this file to `.env` and fill in your own values.

# Required: Hugging Face write token (for downloading private models + uploading checkpoints)
# Create one at https://huggingface.co/settings/tokens with "write" scope.
HF_TOKEN=hf_xxxxx

# Optional alias: some scripts also check HF_API_KEY; set either HF_TOKEN or HF_API_KEY.
HF_API_KEY=

# Optional: Pre-fill your Hugging Face username so uploads don't prompt for it.
HF_USERNAME=

# Optional: Enable Weights & Biases logging during training.
WANDB_API_KEY=

# Optional: Set a custom Hugging Face cache directory (uncomment to use)
# HF_HOME=/path/to/cache

# ============================================================================
# Dataset Editor LLM Configuration
# ============================================================================

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5-mini

# OpenAI Responses API
OPENAI_API_KEY=
OPENAI_RESPONSES_BASE_URL=https://api.openai.com/v1
OPENAI_RESPONSES_TIMEOUT_SECONDS=60
OPENAI_RESPONSES_STORE=false
OPENAI_RESPONSES_STRUCTURED_OUTPUT_STRICT=false

# LM Studio
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model

# Ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# Custom OpenAI Compatible
CUSTOM_BASE_URL=http://localhost:8000/v1
CUSTOM_API_KEY=
CUSTOM_MODEL=model-name
# Evaluation Backend Settings
# ============================================================================

# LM Studio (for WSL users connecting to LM Studio on Windows)
# ----------------------------------------------------------------------------
# If running from WSL and LM Studio is on Windows, you need to set the host IP.
#
# To find your IP:
#   1. Open LM Studio on Windows
#   2. Click "Developer" in the left sidebar
#   3. Go to "Server" settings
#   4. Toggle ON "Serve on Local Network"
#   5. Note the IP address shown (e.g., 192.168.1.104)
#
# Then set it here:
# LMSTUDIO_HOST=192.168.1.104
# LMSTUDIO_PORT=1234

# Ollama (usually auto-detected, but can override if needed)
# OLLAMA_HOST=127.0.0.1
# OLLAMA_PORT=11434

# vLLM (for vLLM backend)
# VLLM_HOST=127.0.0.1
# VLLM_PORT=8000

# E2B (optional, for environment-backed tool execution/evaluation)
# ----------------------------------------------------------------------------
# E2B_API_KEY=e2b_xxxxx
# Optional: default E2B template ID used by evaluator/synthchat when enabled
# E2B_TEMPLATE=
