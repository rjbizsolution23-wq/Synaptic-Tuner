FROM {{BASE_IMAGE}}

USER root

RUN useradd -m -u 1000 user || true \
    && mkdir -p /data /home/user/app \
    && chown -R 1000:1000 /data /home/user

RUN python3 -m venv /opt/bucket-sync-venv \
    && /opt/bucket-sync-venv/bin/pip install --upgrade pip \
    && /opt/bucket-sync-venv/bin/pip install "huggingface_hub[hf_transfer]>=1.0.0"

ENV HOME=/home/user
ENV PATH=/home/user/.local/bin:$PATH
ENV HF_HOME=/data/.huggingface
ENV PIP_CACHE_DIR=/data/.cache/pip
ENV HF_HUB_ENABLE_HF_TRANSFER=1
ENV USE_TORCH=1
ENV USE_TF=0
ENV SPACE_APP_PORT={{APP_PORT}}

WORKDIR /home/user/app

COPY --chown=user:user entrypoint.sh /home/user/app/entrypoint.sh
COPY --chown=user:user sync_bucket_prefix.py /home/user/app/sync_bucket_prefix.py

RUN chmod +x /home/user/app/entrypoint.sh

USER user

EXPOSE {{APP_PORT}}

ENTRYPOINT []
CMD ["bash", "/home/user/app/entrypoint.sh"]
